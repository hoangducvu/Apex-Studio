# ── Stripe keys ────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... while testing, switch to live keys when ready

STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret — get from Stripe Dashboard > Webhooks
# or from the Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3000

# Admin panel — set a strong password
ADMIN_PASSWORD=change_me_to_something_strong

# Owner email notifications (remove/comment these lines to skip emails)
OWNER_EMAIL=you@youremail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
